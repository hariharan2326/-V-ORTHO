# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# RAZORPAY_KEY_ID: Required for Razorpay payment integration gateways.
# Users should obtain this key from their Razorpay Dashboard settings (API Keys).
# Configure this via the Secrets panel in the AI Studio UI.
RAZORPAY_KEY_ID=rzp_test_placeholder_key_id

# SUPABASE_URL: The base URL of your Supabase project.
SUPABASE_URL=https://howrghnrbalwcvysvzct.supabase.co

# SUPABASE_ANON_KEY: The public anonymous API key of your Supabase project.
# Configure this securely via the Secrets panel in the AI Studio UI or settings.
SUPABASE_ANON_KEY=YOUR_ANON_KEY

